meta {
  name: CrearUsuario
  type: http
  seq: 3
}

script:pre-request {
  bru.setVar("bruSuffix", Date.now());
}

post {
  url: http://localhost:8080/api/users
  body: json
  auth: none
}

body:json {
  {
    "name": "Usuario Prueba Bruno",
    "email": "bruno.test.{{bruSuffix}}@example.com",
    "password": "ClaveSegura123"
  }
}

script:post-response {
  bru.setVar("bruUserId", res.body.id);
}
